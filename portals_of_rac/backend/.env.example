MONGODB_URI=mongodb://localhost:27017
#MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
#MONGO_URI =mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# ═══════════════════════════════════════════════════
# Database Names
# ═══════════════════════════════════════════════════
STATIONS_DB=rac
PASSENGERS_DB=PassengersDB
TRAIN_DETAILS_DB=rac

# ═══════════════════════════════════════════════════
# Collection Names
# ═══════════════════════════════════════════════════
# (Train-specific collections like passengers/stations come from Trains_Details)
TRAIN_DETAILS_COLLECTION=Trains_Details
TTE_USERS_COLLECTION=tte_users
PASSENGER_ACCOUNTS_COLLECTION=passenger_accounts
REFRESH_TOKENS_COLLECTION=refresh_tokens
PUSH_SUBSCRIPTIONS_COLLECTION=push_subscriptions
IN_APP_NOTIFICATIONS_COLLECTION=in_app_notifications
UPGRADE_NOTIFICATIONS_COLLECTION=upgrade_notifications
STATION_REALLOCATIONS_COLLECTION=station_reallocations
OTP_STORE_COLLECTION=otp_store
UPGRADE_DENIAL_LOG_COLLECTION=upgrade_denial_log

# (Train-specific defaults now come from Trains_Details collection)

# ═══════════════════════════════════════════════════
# Server Config
# ═══════════════════════════════════════════════════
PORT=5000
NODE_ENV=production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174,http://localhost:5175,https://rac-admin-page.vercel.app,https://rac-tte.vercel.app,https://passengerportal.vercel.app

# ═══════════════════════════════════════════════════
# Web Push (VAPID)
# ═══════════════════════════════════════════════════
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:your-email@example.com
VAPID_SUBJECT=mailto:your-email@example.com

# ═══════════════════════════════════════════════════
# Auth (JWT)
# ═══════════════════════════════════════════════════
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ═══════════════════════════════════════════════════
# Email (SMTP)
# ═══════════════════════════════════════════════════
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here




