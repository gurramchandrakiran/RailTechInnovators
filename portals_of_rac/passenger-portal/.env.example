# ==========================================
# Passenger Portal Environment Variables
# ==========================================
# Copy this file to .env and fill in the values

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# WebSocket URL
VITE_WS_URL=ws://localhost:5000

# QR Code Base URL (auto-detected from LAN IP in vite.config.js if not set)
# VITE_QR_BASE_URL=http://localhost:5175
